# =============================================================================
# Lovable environment reference (modest-chic-builder)
# =============================================================================
# Do NOT commit real secrets. Lovable injects values via Project Settings.
# Local dev: copy to .env only if Lovable has not auto-synced one for you.
# =============================================================================

# --- Lovable Cloud (Supabase) — auto-managed ---
# Powers Lovable Cloud backend (edge functions, DB). NOT used for products,
# cart, or checkout — that is all Shopify. You do not configure this manually
# in normal Lovable workflow; migrations go through Lovable SQL editor + GitHub.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- Shopify Storefront API — commerce backend ---
# Public Storefront token lets the React app read products and manage cart via
# GraphQL. This is SHOPIFY, not Supabase.
#
# In Lovable Project Settings the secret is typically named:
#   SHOPIFY_STOREFRONT_ACCESS_TOKEN
# The app reads it at runtime via VITE_SHOPIFY_STOREFRONT_TOKEN (Vite client
# env convention). Lovable may map these automatically when Shopify integration
# is connected — check Settings if products fail to load locally.
VITE_SHOPIFY_STORE_DOMAIN=modest-streetwear-apparel.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=

# --- Analytics (optional) — set in Lovable Project Settings ---
VITE_GA_MEASUREMENT_ID=
VITE_META_PIXEL_ID=
